# AetherCloud VPS2 environment template.
#
# USAGE:
#   1. Copy this file to /opt/aether/.env on the server
#   2. Fill in every placeholder below
#   3. chmod 600 /opt/aether/.env ; chown aether:aether /opt/aether/.env
#   4. systemctl restart aether
#
# NEVER commit the real .env to git. .gitignore blocks *.env.* except for
# this file. If you rotate a secret, update both this template's comments
# (explaining where to get it) and the live .env on the server.
#
# Every variable below is REQUIRED unless marked OPTIONAL.

# ══════════════════════════════════════════════════════════════════
# Stage J — feature flag (the UVT kill switch)
# ══════════════════════════════════════════════════════════════════

# Global flag — when true, ALL users hit the UVT pipeline. Leave false
# during the rollout and flip last per the vps2-runbook checklist.
AETHER_UVT_ENABLED=false

# Percentage rollout (0-100). Deterministic by user_id hash. When set
# and non-zero, users in the hash bucket < this value get UVT regardless
# of the global flag. Users NOT in the bucket fall through to the global
# flag — so the documented staged-rollout combo is:
#     AETHER_UVT_ENABLED=false  AETHER_UVT_ROLLOUT_PCT=5
AETHER_UVT_ROLLOUT_PCT=0

# Per-user overrides — wins over both rollout and global. Format:
#     AETHER_UVT_USER_OVERRIDES=uuid-1:true,uuid-2:false,uuid-3:true
# Use this to canary-test as yourself before ramping rollout.
AETHER_UVT_USER_OVERRIDES=

# ══════════════════════════════════════════════════════════════════
# Anthropic — TokenAccountant reads this at call time (hot-rotatable)
# ══════════════════════════════════════════════════════════════════
# Get a fresh key at https://console.anthropic.com/settings/keys
# Rotate per the Security runbook every 90 days.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ══════════════════════════════════════════════════════════════════
# Supabase
# ══════════════════════════════════════════════════════════════════
# Project dashboard → Settings → API
# SERVICE_ROLE_KEY bypasses RLS — only set in trusted server env.
# The anon key is NEVER used on VPS2 (client-side only).
SUPABASE_URL=https://cjjcdwrnpzwlvradbros.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# ══════════════════════════════════════════════════════════════════
# Stripe — required by lib/uvt_routes.py overage gate + webhook
# ══════════════════════════════════════════════════════════════════
# Stripe dashboard → Developers → API keys (live mode).
# Rotate per Security runbook.
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
# Stripe dashboard → Webhooks → select endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs per tier — updated 2026-04-21 to the $19.99/$49.99/$89.99 set.
# See docs/superpowers/specs/2026-04-20-aethersystems-net-checkout-wiring-design.md
# for why we kept tier keys (solo/pro/team) stable while renaming display.
STRIPE_PRICE_AETHER_CLOUD_SOLO=price_1TOhH33TqWOqdd87qbWtG5ZG
STRIPE_PRICE_AETHER_CLOUD_PRO=price_1TOhH23TqWOqdd87AxosMSfb
STRIPE_PRICE_AETHER_CLOUD_TEAM=price_1TOhH23TqWOqdd87M3w25HEE

# ══════════════════════════════════════════════════════════════════
# Resend (transactional email)
# ══════════════════════════════════════════════════════════════════
# resend.com → API Keys. no-reply@aethersystems.net is configured
# in Resend's dashboard; mirror the sender here.
RESEND_API_KEY=re_REPLACE_ME
FROM_EMAIL=no-reply@aethersystems.net

# ══════════════════════════════════════════════════════════════════
# PostHog (server-side analytics)
# ══════════════════════════════════════════════════════════════════
POSTHOG_KEY=phc_REPLACE_ME
POSTHOG_HOST=https://us.i.posthog.com

# ══════════════════════════════════════════════════════════════════
# AetherCloud app identity
# ══════════════════════════════════════════════════════════════════
# Public base URL of this API (VPS2). Used in redirect URLs + emails.
AETHER_API_BASE=https://api.aethersystems.net

# Marketing site (Stripe checkout success redirects back here).
APP_URL=https://aethersystems.net

# ══════════════════════════════════════════════════════════════════
# Aether Protocol / IBM Quantum — OPTIONAL (fallback: CSPRNG)
# ══════════════════════════════════════════════════════════════════
# AETHER_PROTOCOL_VARIANT=C
# IBM_QUANTUM_API_KEY=

# ══════════════════════════════════════════════════════════════════
# Admin + dev keys — OPTIONAL (needed only for admin license ops)
# ══════════════════════════════════════════════════════════════════
# AETHER_ADMIN_KEY=
# AETHER_DEV_KEY=

# ══════════════════════════════════════════════════════════════════
# Logging + binding — reasonable defaults, override only if needed
# ══════════════════════════════════════════════════════════════════
LOG_LEVEL=info
AETHER_BIND_HOST=127.0.0.1
AETHER_BIND_PORT=8000

# Git SHA — injected by deploy.sh is overkill. /healthz reads from
# `git rev-parse HEAD` at import time, so leave this commented unless
# you deploy from a detached copy without .git.
# AETHER_GIT_SHA=

# Usage-ledger dead-letter queue (Stage A — durable fallback when
# rpc_record_usage fails). Path is writable by the aether user; the
# systemd unit adds it to ReadWritePaths.
AETHER_USAGE_DLQ=/var/lib/aethercloud/usage_dlq.jsonl
