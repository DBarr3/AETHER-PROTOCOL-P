# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
# ...but desktop/build/ holds shipping electron-builder hooks (fuses.js,
# check-signing.js) — those are source code, not transient build output.
!desktop/build/
!desktop/build/**
*.egg
.eggs/

# Virtual environments
venv/
.env
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/

# Runtime data
data/
vault_data/
*.db

# Credentials & Secrets — never commit these
config/credentials.json
ibm_credentials.json
*.pem
*.key
*.p12
*.pfx
*.der
*.crt
*.cer
env.py
*.env*
!.env.example

# Claude Code local state (worktrees, session data) — never commit
.claude/
secrets.json
*_secret*
*_private*
tmp_msg.json

# WireGuard keys — never commit
deploy/wg/mesh-keys.txt
deploy/wg/*.private
deploy/wg/*.public
deploy/wg/*.conf

# PyInstaller backend build output
desktop/backend/

# Electron release builds
desktop/release/
desktop/dist/

# Audit / crypto runtime data
crypto/

# Python logs
*.log
logs/

# Tailscale / VPN state
tailscale-state/

# macOS / OS
.DS_Store
Thumbs.db

# Test user vault data — never commit real user data
vault/alice/
vault/bob/
vault/carol/
vault/dave/
vault/testuser/
vault/victim/

# node_modules (belt-and-suspenders; desktop/.gitignore also covers this)
desktop/node_modules/

# electron-store encrypted data files
*.json.locked

# Ed25519 manifest signing private keys — NEVER commit.
*.priv.bin
!**/*-test.pub.bin
