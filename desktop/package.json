{
  "name": "aethercloud-l",
  "version": "0.9.8",
  "description": "Quantum-secured AI file intelligence",
  "main": "main.js",
  "author": "Aether Systems LLC",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "node build/check-signing.js && electron-builder --win",
    "dist": "node build/check-signing.js && electron-builder --win --publish never",
    "dist:signed": "node build/check-signing.js && electron-builder --win --publish never",
    "dist:unsigned": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false AETHER_ALLOW_UNSIGNED=1 electron-builder --win --publish never"
  },
  "dependencies": {
    "dompurify": "^3.4.0",
    "electron-store": "^8.2.0",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.aethersystems.aethercloud",
    "productName": "AetherCloud-L",
    "copyright": "Copyright 2026 Aether Systems LLC",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-machine-id/**"
    ],
    "afterPack": "./build/fuses.js",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "auth-store.js",
      "analysis-cache.js",
      "pages/**/*",
      "assets/**/*",
      "!assets/icon.icns",
      "!assets/icon.png",
      "!**/*.map",
      "!**/*.md",
      "!**/test*",
      "!**/spec*",
      "!**/.git/**",
      "!**/node_modules/.cache/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "AetherCloud-L-Payload-${version}.exe",
      "signtoolOptions": {
        "publisherName": "Aether Systems LLC",
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      },
      "verifyUpdateCodeSignature": true
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AetherCloud-L",
      "uninstallDisplayName": "AetherCloud-L v${version}",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "menuCategory": "Aether Systems LLC",
      "runAfterFinish": true,
      "installerLanguages": [
        "en_US"
      ],
      "warningsAsErrors": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
