{
  "name": "aethercloud-l",
  "version": "0.5.0",
  "description": "AetherCloud-L — Quantum-Secured File Intelligence",
  "main": "main.js",
  "author": "Aether Systems LLC",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prebuild": "cd .. && pyinstaller --onefile --name aethercloud-backend --distpath desktop/backend main.py",
    "dist:win": "npm run prebuild && electron-builder --win --x64",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.aethersystems.aethercloud-l",
    "productName": "AetherCloud-L",
    "copyright": "Copyright © 2026 Aether Systems LLC. Patent Pending.",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "key-manager.js",
      "pages/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/aethercloud-backend.exe",
        "to": "aethercloud-backend.exe"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "license": "LICENSE"
    }
  }
}
