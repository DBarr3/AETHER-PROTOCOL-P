{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "REPLACE_WITH_YOUR_TOKEN"
      }
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@wonderwhy-er/desktop-commander"]
    },
    "excalidraw": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@cmd8/excalidraw-mcp",
        "--diagram",
        "C:/Users/lilbe/aether-diagrams/aether.excalidraw"
      ]
    },
    "fal-ai": {
      "type": "http",
      "url": "https://mcp.fal.ai/mcp",
      "headers": {
        "Authorization": "Bearer 0d87fd60-4833-4ffb-92e2-51bb21830347:bd8a5e5dfa61d3cae3a482ee498b1579"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-playwright"]
    },
    "tavily": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": "REPLACE_WITH_YOUR_TAVILY_KEY"
      }
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-memory"],
      "env": {
        "MEMORY_FILE": "C:/Users/lilbe/Documents/GitHub/AETHER-CLOUD/agent/memory/knowledge.json"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-filesystem", "C:/Users/lilbe/Documents/GitHub/AETHER-CLOUD"]
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-fetch"]
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "REPLACE_WITH_YOUR_BRAVE_KEY"
      }
    },
    "firecrawl": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "REPLACE_WITH_YOUR_FIRECRAWL_KEY"
      }
    },
    "obsidian": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "obsidian-mcp"],
      "env": {
        "OBSIDIAN_VAULT_PATH": "REPLACE_WITH_YOUR_VAULT_PATH"
      }
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "REPLACE_WITH_YOUR_CONNECTION_STRING"
      }
    },
    "puppeteer": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-puppeteer"]
    },
    "taskmaster": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "task-master-ai"],
      "env": {
        "ANTHROPIC_API_KEY": "REPLACE_WITH_YOUR_ANTHROPIC_KEY"
      }
    },
    "promptfoo": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "promptfoo@latest", "mcp"]
    }
  }
}
