# ═══════════════════════════════════════════════════
# AetherCloud-L — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# Claude API Key (required for AI agent)
ANTHROPIC_API_KEY=your_key_here

# Vault root directory
AETHER_VAULT_ROOT=C:/Users/yourname/AetherVault

# Session timeout in hours (default: 8)
AETHER_SESSION_TIMEOUT=8

# Claude model (default: claude-opus-4-5)
AETHER_AGENT_MODEL=claude-opus-4-5

# Max login attempts before lockout (default: 5)
AETHER_MAX_LOGIN_ATTEMPTS=5

# Lockout duration in seconds (default: 900)
AETHER_LOCKOUT_DURATION=900
