# ═══════════════════════════════════════════════════
# AetherCloud-L — Environment Configuration
# ═══════════════════════════════════════════════════
#
# PRODUCTION (VPS2): Place at /etc/aethercloud/.env
#   sudo chmod 600 /etc/aethercloud/.env
#   sudo chown root:root /etc/aethercloud/.env
#
# DEVELOPMENT: Place at ~/.aethercloud/.env
#   or copy to repo root as .env (gitignored)
#
# See: config/key_manager.py for loading logic
# See: scripts/setup_keys.sh for VPS2 setup
# ═══════════════════════════════════════════════════

# Claude API Key (REQUIRED for AI agent)
ANTHROPIC_API_KEY=your_key_here

# Protocol variant: "C" = CSPRNG (default), "L" = quantum (IBM hardware)
# AETHER-PREDATOR and AETHER-SCRAMBLER use "L"; AetherCloud defaults to "C"
AETHER_PROTOCOL_VARIANT=C

# IBM Quantum API Key (optional — only needed when AETHER_PROTOCOL_VARIANT=L)
# Also loadable from ~/.aether/ibm_credentials.json
IBM_QUANTUM_API_KEY=your_ibm_key_here

# Dev user key (optional — has a secure fallback)
AETHER_DEV_KEY=your_dev_key_here

# Server binding (VPS2 uses 0.0.0.0:8080)
AETHER_BIND_HOST=0.0.0.0
AETHER_BIND_PORT=8080

# Vault root directory
AETHER_VAULT_ROOT=C:/Users/yourname/AetherVault

# Session timeout in hours (default: 8)
AETHER_SESSION_TIMEOUT=8

# Claude model (default: claude-opus-4-5)
AETHER_AGENT_MODEL=claude-opus-4-5

# Max login attempts before lockout (default: 5)
AETHER_MAX_LOGIN_ATTEMPTS=5

# Lockout duration in seconds (default: 900)
AETHER_LOCKOUT_DURATION=900

# ── License ──────────────────────────────────────
# AetherCloud subscription key (validated against license server on startup)
AETHERCLOUD_LICENSE_KEY=AETH-CLD-XXXX-XXXX-XXXX
AETHER_LICENSE_SERVER=https://aethersecurity.net/api/license

# Admin key for license server admin endpoints (used by admin dashboard)
AETHER_ADMIN_KEY=your_secure_admin_key_here

# ── MCP Worker (VPS5) ────────────────────────────
# VPS5 Tailscale IP — reachable from VPS2 on port 8095 only
MCP_WORKER_HOST=100.84.205.12
MCP_WORKER_PORT=8095

# VPS2 Ed25519 private key — used to sign requests to VPS5
VPS2_NODE_KEY_PATH=/opt/aether-mcp/certs/VPS2.key

# ── DO Spaces (File Vault cloud storage) ─────────
# DigitalOcean Spaces credentials for per-user vault file storage
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=aethercloud-vault
DO_SPACES_KEY=your_spaces_key_here
DO_SPACES_SECRET=your_spaces_secret_here
