# Local development secrets for Supabase edge functions.
# Copy to .env and fill in. Never commit the real .env.
#
# For PRODUCTION, set these via:
#   supabase secrets set KEY=value
# or Dashboard → Project Settings → Edge Functions → Manage secrets.

# ── Stripe ─────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys (for test)
# or       https://dashboard.stripe.com/apikeys (for live)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Webhook signing secret — create an endpoint at
# https://dashboard.stripe.com/test/webhooks pointing to
# https://cjjcdwrnpzwlvradbros.supabase.co/functions/v1/stripe-webhook
# then copy the signing secret here.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Price IDs for each plan — create these in Stripe first, then map here.
# Used by create-checkout-session to build the correct checkout URL.
STRIPE_PRICE_AETHER_CLOUD_PRO=price_replace_me
STRIPE_PRICE_AETHER_CLOUD_TEAM=price_replace_me
STRIPE_PRICE_AETHER_CLOUD_ENTERPRISE=price_replace_me

# ── Resend (transactional email) ──────────────────────────
# Phase 1 does not require Resend; add when we wire email templates.
# RESEND_API_KEY=re_replace_me
# RESEND_FROM_EMAIL=noreply@aethersystems.net

# ── Auto-provided by Supabase at runtime ──────────────────
# These are injected by the Supabase edge runtime — no need to set them.
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
