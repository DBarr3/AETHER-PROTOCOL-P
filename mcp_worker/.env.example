# ═══════════════════════════════════════════════════
# AETHER MCP WORKER — VPS5 Environment Variables
# ═══════════════════════════════════════════════════

VPS2_ALERT_ENDPOINT=http://<VPS2_IP>/agent/breach-alert
MCP_ALERT_KEY=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))">
ANTHROPIC_API_KEY=<your_anthropic_api_key>

VPS5_NODE_KEY_PATH=/opt/aether-mcp/certs/VPS5.key
VPS2_PUB_KEY_PATH=/opt/aether-mcp/certs/VPS2.pub

MCP_WORKER_PORT=8095
LOG_LEVEL=INFO
MCP_AGENT_MODEL=claude-sonnet-4-20250514
MCP_MAX_TOKENS=2000
MCP_TIMEOUT=30
